    "commander": "^12.0.0",
    "docx": "^8.5.0",
    "ejs": "^3.1.9",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1",
    "puppeteer": "^22.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }

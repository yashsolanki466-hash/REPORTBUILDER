{
  "name": "ngs-report-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "NGS Report Generation CLI - High-quality HTML/PDF/DOCX reports from project deliverables",
  "main": "dist/cli.js",
  "bin": {
    "ngs-report": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "node dist/cli.js",

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title> Unigenome <%= project_id %></title>

    <!-- Dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --primary-color: #F47920;
            --secondary-color: #1A365D;
            --accent-color: #3182CE;
            --text-main: #2D3748;
            --text-muted: #718096;
            --bg-body: #F7FAFC;
            --bg-sidebar: rgba(255, 255, 255, 0.85);
            --bg-paper: #FFFFFF;
            --border-color: #E2E8F0;
            --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --glass-blur: blur(12px);
        }

        body {
            font-family: 'Lora', "Times New Roman", serif;
            font-size: 11pt;
            line-height: 1.62;
            color: var(--text-main);
            background-color: var(--bg-body);
            margin: 0;
            padding-left: 280px;
            transition: background-color 0.3s ease, color 0.3s ease;
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }

        h1, h2, h3, h4, .ui-font {
            font-family: 'Inter', system-ui, sans-serif;
        }

        p {
            margin-bottom: 1.2rem;
            text-align: justify;
        }

        .section {
            scroll-margin-top: 40px;
        }

        /* Fixed TOC Sidebar Style (Screen Only) */
        #TOC {
            position: fixed;
            top: 0;
            left: 0;
            width: 280px;
            height: 100vh;
            overflow-y: auto;
            background: var(--bg-sidebar);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border-right: 1px solid var(--border-color);
            padding: 40px 0;
            z-index: 1000;
            transition: all 0.3s ease;
        }

        .toc-header {
            padding: 0 32px 24px 32px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        #TOC ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        #TOC li a {
            display: block;
            padding: 12px 32px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-left: 4px solid transparent;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #TOC li a:hover {
            color: var(--secondary-color);
            background: rgba(0, 0, 0, 0.02);
        }

        #TOC li a.active {
            color: var(--secondary-color);
            background: rgba(49, 130, 206, 0.08);
            border-left: 4px solid var(--secondary-color);
            font-weight: 600;
        }

        /* Content Area */
        .main-container {
            margin: 40px auto;
            padding: 80px 100px;
            max-width: 1000px;
            background-color: var(--bg-paper);
            box-shadow: var(--card-shadow);
            border-radius: 8px;
            box-sizing: border-box;
            border: 1px solid var(--border-color);
        }

        /* Cover Page */
        .cover-page {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            text-align: center;
            padding: 50px;
            box-sizing: border-box;
            page-break-after: always;
        }

        .cover-logo {
            max-width: 300px;
            margin-bottom: 40px;
        }

        .cover-title {
            font-size: 34px;
            font-weight: 800;
            color: #000;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .cover-subtitle {
            font-size: 22px;
            font-weight: 600;
            color: #000;
            margin-bottom: 40px;
        }

        .cover-details {
            font-size: 16px;
            color: var(--primary-color);
            font-weight: bold;
            margin-bottom: 60px;
        }

        .submitted-by {
            margin-top: 25px;
            color: #333;
            font-size: 12px;
            line-height: 1.4;
        }

        .submitted-to {
            margin-top: auto;
            color: var(--secondary-color);
            font-weight: bold;
            font-size: 18px;
        }

        /* Typography */
        h1.title {
            font-size: 28px;
            margin-top: 0;
            margin-bottom: 10px;
            font-weight: 700;
            color: var(--secondary-color);
        }

        .subtitle {
            font-size: 16px;
            color: #666;
            margin-bottom: 30px;
            font-weight: 400;
        }

        h2 {
            font-size: 22px;
            color: var(--secondary-color);
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 8px;
            margin-top: 40px;
            margin-bottom: 20px;
            font-weight: 700;
            page-break-after: avoid;
        }

        h3 {
            font-size: 16px;
            font-weight: bold;
            margin-top: 25px;
            margin-bottom: 15px;
            color: var(--secondary-color);
            page-break-after: avoid;
        }

        h4 {
            font-size: 14px;
            font-weight: bold;
            margin-top: 20px;
            margin-bottom: 10px;
            color: #555;
        }

        /* Tables */
        .table-wrapper {
            overflow-x: auto;
            margin: 20px 0 30px 0;
            page-break-inside: avoid;
        }

        .table-title {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 8px;
            color: var(--secondary-color);
        }

        table {
            width: 100%;
            max-width: 100%;
            border-spacing: 0;
            border-collapse: collapse;
            border: 1px solid #ddd;
            font-size: 11px;
        }

        table th {
            padding: 8px 10px;
            background-color: var(--secondary-color);
            color: #fff;
            border: 1px solid var(--secondary-color);
            text-align: left;
            font-weight: 700;
            text-transform: uppercase;
        }

        table td {
            padding: 6px 10px;
            border: 1px solid #ddd;
            vertical-align: middle;
        }

        table tr:nth-of-type(even) {
            background-color: #f2f2f2;
        }

        /* Figures */
        .figure {
            margin: 30px 0;
            text-align: center;
            background: #fff;
            padding: 10px;
            page-break-inside: avoid;
        }

        .figure img {
            max-width: 100%;
            height: auto;
        }

        .caption {
            font-size: 11px;
            color: var(--secondary-color);
            margin-top: 10px;
            font-style: italic;
            font-weight: 600;
        }

        /* Info Box */
        .info-box {
            padding: 20px;
            margin-bottom: 25px;
            border-left: 5px solid var(--primary-color);
            background-color: #f9f9f9;
            color: #333;
        }

        .mono {
            font-family: "Times New Roman", Times, serif;
            font-size: 11px;
        }

        .confidential {
            color: #999;
            font-size: 10px;
            margin-top: 5px;
            text-align: right;
        }

        /* Print Formatting */
        @media print {
            @page {
                size: A4;
                margin: 20mm 20mm 20mm 20mm;
            }

            @page :first {
                margin: 0;
            }

            body {
                background-color: #fff !important;
                font-size: 10.5pt;
                line-height: 1.55;
                margin: 0;
                padding: 0 !important;
                width: 100% !important;
            }

            #TOC {
                display: none;
            }

            .main-container {
                margin: 0 auto;
                padding: 0;
                width: 100%;
                max-width: none;
                background: transparent;
                box-shadow: none;
                border-radius: 0;
                border: none;
            }

            .table-wrapper, table, .figure {
                break-inside: avoid;
            }

            thead {
                display: table-header-group;
            }

            h2 {
                page-break-after: avoid;
                page-break-before: auto;
                margin-top: 30px;
            }

            h3 {
                page-break-after: avoid;
                page-break-before: auto;
            }

            .section {
                page-break-inside: avoid;
            }

            .cover-page {
                page-break-after: always;
            }
        }
    </style>
</head>

<body>

    <div id="TOC">
        <div class="toc-header">
            <div style="font-weight: 800; color: var(--primary-color); font-size: 18px; letter-spacing: 0.5px; font-family: 'Inter', sans-serif;">
                UNIGENOME</div>
            <div style="font-size: 12px; color: var(--text-muted); font-family: 'Inter', sans-serif;">Final Analysis
                Report</div>
        </div>
        <ul style="margin-top: 10px;">
            <li><a href="#section-1" class="active">1 Project Details</a></li>
            <li><a href="#section-2">2 Sample Information</a></li>
            <li><a href="#section-3">3 Methods</a></li>
            <li><a href="#section-4">4 Library QC</a></li>
            <li><a href="#section-5">5 Bioinformatics Analysis</a></li>
            <li><a href="#section-6">6 Data Statistics</a></li>
            <li><a href="#section-7">7 Reference Genome</a></li>
            <li><a href="#section-8">8 Mapping to Reference</a></li>
            <li><a href="#section-9">9 Transcript Assembly</a></li>
            <li><a href="#section-10">10 Differential Expression</a></li>
            <li><a href="#section-11">11 Functional Annotation</a></li>
            <li><a href="#section-12">12 Deliverables</a></li>
        </ul>
    </div>

    <div class="main-container">

        <!-- Cover Page -->
        <div class="cover-page">
            <div style="width: 100%;">
                <img src="<%= logo_path %>" alt="Unigenome Logo" class="cover-logo">
            </div>

            <div>
                <div class="cover-title">Final Report of</div>
                <div class="cover-subtitle">Whole Transcriptome Sequencing<br>& Analysis</div>
                <div class="cover-details">On Illumina Novaseq X Plus Platform</div>
                <div class="cover-details" style="font-size: 18px; margin-top: 10px;">Project ID: <%= project_id %></div>
            </div>

            <div class="submitted-to">
                <p style="margin-bottom: 5px;">Submitted to:</p>
                <div style="font-size: 22px; color: var(--primary-color);"><%= client_name %></div>
                <div style="font-size: 16px; color: #333;"><%= client_org %></div>

                <div class="submitted-by">
                    <div style="font-weight: bold; margin-top: 18px;">Submitted by:</div>
                    <div style="font-weight: 700;">Unigenome</div>
                    <div>A life sciences division of Unipath Specialty Laboratory Ltd.</div>
                    <div>3rd Floor, PASL House | Beside Sahjanand College | Panjara pol, Ambawadi,</div>
                    <div>Ahmedabad – 380015 | Gujarat, India</div>
                    <div>Tel :- +91-79-66197701</div>
                    <div>genomics@unipath.in | www.unigenome.in</div>
                </div>
            </div>

            <div style="width: 100%; border-top: 2px solid var(--primary-color); padding-top: 10px; margin-top: 40px; font-size: 10px; color: #666;">
                Unigenome | Confidential | <%= project_id %> | <%= report_date %>
            </div>
        </div>

        <!-- Section 1 -->
        <% if (warnings && warnings.length > 0) { %>
        <div id="section-warnings" class="section">
            <h2>Input Validation Warnings</h2>
            <div class="table-wrapper">
                <div class="table-title">Warnings detected while scanning the deliverables folder</div>
                <table>
                    <thead>
                        <tr>
                            <th>Warning</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% warnings.forEach(function(w) { %>
                        <tr>
                            <td><%= w %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

        <div id="section-1" class="section">
            <h2>1 Project Details</h2>
            <p>This report details the whole transcriptome sequencing and bioinformatics analysis for the project <%= project_id %>. Sequencing was carried out using high-throughput technology to provide deep coverage of the transcriptome.</p>
            
            <% if (project_pi || application || no_of_samples) { %>
            <div class="table-wrapper">
                <div class="table-title">Project Metadata</div>
                <table>
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (project_pi) { %>
                        <tr>
                            <td>Project PI</td>
                            <td><%= project_pi %></td>
                        </tr>
                        <% } %>
                        <% if (application) { %>
                        <tr>
                            <td>Application</td>
                            <td><%= application %></td>
                        </tr>
                        <% } %>
                        <% if (no_of_samples) { %>
                        <tr>
                            <td>No. of Samples</td>
                            <td><%= no_of_samples %></td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            <% } %>
            
            <div class="table-wrapper">
                <div class="table-title">Table 1.1: Project Specifications</div>
                <table>
                    <thead>
                        <tr>
                            <th>Service Type</th>
                            <th>Platform</th>
                            <th>Read Length</th>
                            <th>Data Throughput</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Transcriptome Sequencing</td>
                            <td>Illumina Novaseq X Plus</td>
                            <td>2 X 150 PE</td>
                            <td>~05 GB / Sample</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Section 2 -->
        <div id="section-2" class="section">
            <h2>2 Sample Information</h2>
            <p>A total of <%= sample_count %> samples were received for library preparation and sequencing. The samples were collected from plant root tissues and maintained under strict temperature controls during transport.</p>
            <div class="table-wrapper">
                <div class="table-title">Table 2.1: Sample Overview</div>
                <table>
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>No. of Samples</th>
                            <th>Shipping Condition</th>
                            <th>Libraries Prepared</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Plant Root</td>
                            <td><%= sample_count %></td>
                            <td>-20°C</td>
                            <td><%= sample_count %></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p><strong>Sample Nomenclature:</strong> <%= samples.join(', ') %></p>
        </div>

        <!-- Section 3 -->
        <div id="section-3" class="section">
            <h2>3 Methods</h2>

            <h3>3.1 Isolation and Quantitative analysis of RNA:</h3>
            <p><%= static_snippets.wet_lab?.rna_isolation_qc || 'RNA samples were extracted from tissue sample using QIAGEN RNeasy mini kit. RNA quantity was measured using Qubit® 4.0 fluorometer and quality were analyzed by using 1% agarose gel.' %></p>

            <h3>3.2 Preparation of Library</h3>
            <p><%= static_snippets.wet_lab?.library_preparation || 'The paired-end sequencing library was prepared using NEBNext® Ultra™ RNA Library Prep Kit for Illumina.' %></p>

            <h3>3.3 Quantification using Qubit 4.0 Fluorometer</h3>
            <div class="table-wrapper">
                <div class="table-title">Table 3.1: RNA Quantification (Qubit)</div>
                <table>
                    <thead>
                        <tr>
                            <th>S.N</th>
                            <th>Sample ID</th>
                            <th>Conc. (ng/µl)</th>
                            <th>Volume (µl)</th>
                            <th>Yield (µg)</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (qubit_data && qubit_data.length > 0) { %>
                            <% qubit_data.forEach(function(q, i) { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><%= q.sample_id %></td>
                                <td><%= q.conc %></td>
                                <td><%= q.vol %></td>
                                <td><%= q.yield %></td>
                                <td><%= q.remarks %></td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                        <tr>
                            <td colspan="6">No Qubit data available</td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <h3>3.4 Cluster Generation and Sequencing</h3>
            <p><%= static_snippets.wet_lab?.cluster_generation || 'After obtaining the Qubit concentration for the library and the mean peak size from Tape Station profile, library will be loaded onto illumine Novaseq X Plus for cluster generation and sequencing.' %></p>
        </div>

        <!-- Section 4 -->
        <div id="section-4" class="section">
            <h2>4 Library Quality Control</h2>
            <p>Amplified libraries were analyzed on a TapeStation 4150 (Agilent Technologies) using High Sensitivity D1000 ScreenTape® to determine mean peak sizes and ensure proper fragment distribution.</p>

            <div class="figure">
                <div style="height: 300px; width: 100%;">
                    <canvas id="qcChart"></canvas>
                </div>
                <p class="caption">Figure 4.1: Mean library peak size distribution (bp) validated via TapeStation 4150.</p>
            </div>

            <h4>4.1 Wet Lab Inferences</h4>
            <p>The average sizes of the generated libraries were determined to be <%= library_sizes.join(', ') %> respectively for the <%= sample_count %> samples. All libraries met the concentration and size requirements for high-quality sequencing on the Novaseq X Plus platform.</p>
        </div>

        <!-- Section 5 -->
        <div id="section-5" class="section">
            <h2>5 Bioinformatics Analysis</h2>
            <p><%= static_snippets.bioinformatics?.analysis_intro || 'Bioinformatics analysis includes read filtering, mapping, assembly, differential expression, and functional annotation.' %></p>

            <% if (workflow_figure_src) { %>
            <div class="figure">
                <img src="<%= workflow_figure_src %>" alt="Bioinformatics workflow" />
                <p class="caption">Figure 6: Bioinformatics Analysis Workflow</p>
            </div>
            <% } %>
            
            <h3>5.1 Bioinformatics Workflow</h3>
            <p><%= static_snippets.bioinformatics?.workflow_narrative || 'Workflow overview: Raw data was filtered to remove adapters and low-quality bases. Clean reads thus produced were used for analysis.' %></p>

            <h3>5.2 Detail of Software used for analysis</h3>
            <div class="table-wrapper">
                <div class="table-title">Table 5.1: Software Stack</div>
                <table>
                    <thead>
                        <tr>
                            <th>Software</th>
                            <th>Version</th>
                            <th>Application</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% const wfRows = static_snippets.workflow?.software_table?.rows || []; %>
                        <% if (wfRows && wfRows.length > 0) { %>
                            <% wfRows.forEach(function(r) { %>
                            <tr>
                                <td><%= r[0] %></td>
                                <td><%= r[1] %></td>
                                <td><%= r[2] %></td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                        <tr>
                            <td>Trim Galore</td>
                            <td>0.6.4</td>
                            <td>Adapter and low-quality data removal</td>
                        </tr>
                        <tr>
                            <td>STAR</td>
                            <td>2.7.10</td>
                            <td>Mapping of reads to reference genome</td>
                        </tr>
                        <tr>
                            <td>Stringtie</td>
                            <td>2.2.1</td>
                            <td>Reference based assembly</td>
                        </tr>
                        <tr>
                            <td>gffcompare</td>
                            <td>0.12.6</td>
                            <td>Comparing reference genome gff with merged gff file generated from stringtie</td>
                        </tr>
                        <tr>
                            <td>Blastx</td>
                            <td>2.30.0+</td>
                            <td>Similarity search against NCBI NR database</td>
                        </tr>
                        <tr>
                            <td>edgeR</td>
                            <td>3.6.2</td>
                            <td>Differential expression analysis and its visualization</td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Section 6 -->
        <div id="section-6" class="section">
            <h2>6 Data Statistics</h2>
            <p><%= static_snippets.data_stats?.illumina_intro || 'Next-generation sequencing statistics for raw data generated on the Novaseq platform are provided in the table below.' %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 6.1: Sequencing Data Statistics</div>
                <table>
                    <thead>
                        <tr>
                            <th>Sample</th>
                            <th>Total Reads in R1</th>
                            <th>Total Reads in R2</th>
                            <th>Total Reads (R1+R2)</th>
                            <th>Total Bases</th>
                            <th>Data (GB)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% sequencing_stats.forEach(function(s) { %>
                        <tr>
                            <td><%= s.sample %></td>
                            <td class="mono"><%= s.total_reads_r1 || 'N/A' %></td>
                            <td class="mono"><%= s.total_reads_r2 || 'N/A' %></td>
                            <td class="mono"><%= s.total_reads || 'N/A' %></td>
                            <td class="mono"><%= s.total_bases || 'N/A' %></td>
                            <td class="font-bold"><%= s.data_gb || 'N/A' %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Section 7 -->
        <div id="section-7" class="section">
            <h2>7 Reference Genome</h2>
            <p><%= static_snippets.reference?.genome_source || 'The reference genome of ' + reference_organism + ' was used for alignment and annotation.' %></p>
            <p><%= static_snippets.reference?.gff_annotation || 'The corresponding GFF file contains locus and structural information regarding ' + total_genes + ' genes.' %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 7.1: Reference Genome Statistics</div>
                <table>
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th>Stats</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Total Chromosomes/Scaffolds</td>
                            <td><%= ref_stats?.total_scaffolds || 'N/A' %></td>
                        </tr>
                        <tr>
                            <td>Total Genome Length (bp)</td>
                            <td><%= ref_stats?.genome_length || 'N/A' %></td>
                        </tr>
                        <tr>
                            <td>Mean Scaffold Size</td>
                            <td><%= ref_stats?.mean_scaffold_size || 'N/A' %></td>
                        </tr>
                        <tr>
                            <td>Max Scaffold Size (bp)</td>
                            <td><%= ref_stats?.max_scaffold_size || 'N/A' %></td>
                        </tr>
                        <tr>
                            <td>Total Genes Annotated</td>
                            <td><%= total_genes %></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Section 8 -->
        <div id="section-8" class="section">
            <h2>8 Mapping to Reference</h2>
            <p><%= static_snippets.mapping?.star_methodology || 'Alignment to the reference genome allows the identification of reads originating from specific loci. Mapping results show high percentages of uniquely mapped reads for most samples.' %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 8.1: Mapping Statistics</div>
                <table>
                    <thead>
                        <tr>
                            <th>Sample Name</th>
                            <th>Total Clean Reads</th>
                            <th>No. of Mapped Reads</th>
                            <th>% Mapped</th>
                            <th># Uniquely Mapped</th>
                            <th>% Uniquely Mapped</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% mapping_stats.forEach(function(m) { %>
                        <tr>
                            <td><%= m.sample_name %></td>
                            <td class="mono"><%= m.total_reads || 'N/A' %></td>
                            <td class="mono"><%= m.mapped_reads || 'N/A' %></td>
                            <td><%= m.percent_mapped || 'N/A' %></td>
                            <td class="mono"><%= m.unique_reads || 'N/A' %></td>
                            <td><%= m.percent_unique || 'N/A' %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Section 9 -->
        <div id="section-9" class="section">
            <h2>9 Transcript Assembly</h2>
            <p><%= static_snippets.assembly?.stringtie_methodology || 'StringTie assembles transcripts from RNA-seq reads that have been aligned to the genome.' %></p>
            <p><%= static_snippets.assembly?.stringtie_merge || 'After assembling each sample, the full set of assemblies is passed to StringTie\'s merge function.' %></p>

            <% if (stringtie_merge_figure_src) { %>
            <div class="figure">
                <img src="<%= stringtie_merge_figure_src %>" alt="StringTie merge illustration" />
                <p class="caption"><%= static_snippets.assembly?.stringtie_merge_caption || '' %></p>
            </div>
            <% } %>

            <div class="table-wrapper">
                <div class="table-title">Table 9.1: Assembly Statistics</div>
                <table>
                    <thead>
                        <tr>
                            <th>Sample Name</th>
                            <th># Assembled Transcripts</th>
                            <th>Total (bp)</th>
                            <th>Mean Size (bp)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% assembly_stats.forEach(function(a) { %>
                        <tr>
                            <td><%= a.sample %></td>
                            <td class="mono"><%= a.num_transcripts %></td>
                            <td class="mono"><%= a.total_bp || 'N/A' %></td>
                            <td><%= a.mean_size %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <h3>9.1 Comparison of assembled transcripts with reference transcripts</h3>
            <p><%= static_snippets.assembly?.gffcompare_methodology || 'For comparison of assembled transcripts with reference transcripts, Gffcompare utility was run.' %></p>

            <% if (gffcompare_codes_src) { %>
            <div class="figure">
                <img src="<%= gffcompare_codes_src %>" alt="Gffcompare class codes" />
                <p class="caption">Figure 9.1: Different class codes and their descriptions</p>
            </div>
            <% } %>

            <h3>9.2 Identification of novel isoform transcripts</h3>
            <p><%= static_snippets.assembly?.novel_isoforms || 'To identify novel isoform transcripts not present in the reference GTF file, gffcompare utility was run.' %></p>

            <% if (isoforms_figure_src) { %>
            <div class="figure">
                <img src="<%= isoforms_figure_src %>" alt="Novel isoforms illustration" />
                <p class="caption">Novel isoforms (representative illustration)</p>
            </div>
            <% } %>
        </div>

        <!-- Section 10 -->
        <div id="section-10" class="section">
            <h2>10 Differential Expression</h2>
            <p><%= static_snippets.dge?.intro || '' %></p>

            <h3>Comparison information</h3>
            <div class="table-wrapper">
                <div class="table-title">Table 10.1: Comparison information</div>
                <% const dgeCmp = dge_comparison_table || static_snippets.dge?.comparison_info_table; %>
                <% const dgeCmpRows = dgeCmp?.rows || []; %>
                <table>
                    <thead>
                        <tr>
                            <% (dgeCmp?.headers || []).forEach(function(h) { %>
                            <th><%= h %></th>
                            <% }); %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (dgeCmpRows && dgeCmpRows.length > 0) { %>
                            <% dgeCmpRows.forEach(function(r) { %>
                            <tr>
                                <td><%= r[0] %></td>
                                <td><%= r[1] %></td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                        <tr>
                            <td colspan="2">Comparison table unavailable</td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <h3>Group wise sample information</h3>
            <div class="table-wrapper">
                <div class="table-title">Table 10.2: Sample description</div>
                <% const dgeGrp = dge_group_table || static_snippets.dge?.group_sample_table; %>
                <% const dgeGrpRows = dgeGrp?.rows || []; %>
                <table>
                    <thead>
                        <tr>
                            <% (dgeGrp?.headers || []).forEach(function(h) { %>
                            <th><%= h %></th>
                            <% }); %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (dgeGrpRows && dgeGrpRows.length > 0) { %>
                            <% dgeGrpRows.forEach(function(r) { %>
                            <tr>
                                <td><%= r[0] %></td>
                                <td><%= r[1] %></td>
                            </tr>
                            <% }); %>
                        <% } else { %>
                        <tr>
                            <td colspan="2">Group table unavailable</td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <p><%= static_snippets.dge?.deseq2_intro || '' %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 10.3: Column description of DESeq2 output</div>
                <% const dgeCols = static_snippets.dge?.deseq2_columns_table; %>
                <% const dgeColsRows = dgeCols?.rows || []; %>
                <% if (dgeColsRows && dgeColsRows.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <% (dgeCols?.headers || []).forEach(function(h) { %>
                            <th><%= h %></th>
                            <% }); %>
                        </tr>
                    </thead>
                    <tbody>
                        <% dgeColsRows.forEach(function(r) { %>
                        <tr>
                            <td><%= r[0] %></td>
                            <td><%= r[1] %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <% } %>
            </div>

            <p><%= static_snippets.dge?.criteria_intro || '' %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 10.4: Criteria used to identify upregulated and downregulated genes</div>
                <% const dgeCrit = static_snippets.dge?.criteria_table; %>
                <% const dgeCritRows = dgeCrit?.rows || []; %>
                <% if (dgeCritRows && dgeCritRows.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <% (dgeCrit?.headers || []).forEach(function(h) { %>
                            <th><%= h %></th>
                            <% }); %>
                        </tr>
                    </thead>
                    <tbody>
                        <% dgeCritRows.forEach(function(r) { %>
                        <tr>
                            <td><%= r[0] %></td>
                            <td><%= r[1] %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <% } %>
            </div>

            <p><%= static_snippets.dge?.stats_note || '' %></p>
            <div class="table-wrapper">
                <div class="table-title">Table 10.5: Differential expression analysis statistics</div>
                <table>
                    <thead>
                        <tr>
                            <th>Comparison</th>
                            <th>Total Genes</th>
                            <th>Significantly Upregulated</th>
                            <th>Significantly Downregulated</th>
                            <th>Total Significant</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% diff_expr_stats.forEach(function(d) { %>
                        <tr>
                            <td><%= d.comparison %></td>
                            <td><%= d.total_genes %></td>
                            <td><%= d.sig_up %></td>
                            <td><%= d.sig_down %></td>
                            <td class="font-bold"><%= d.total_sig %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <p><%= static_snippets.dge?.annotation_note || '' %></p>

            <% if (dge_figures && dge_figures.length > 0) { %>
            <h3>10.1 MA Plot for differentially expressed genes</h3>
            <p><%= static_snippets.dge?.ma_plot_text || '' %></p>

            <h3>10.2 Volcano plot for differentially expressed genes</h3>
            <p><%= static_snippets.dge?.volcano_plot_text || '' %></p>
            <p>Interactive MA and Volcano plots are provided below for each comparison. These plots visualize the distribution of differentially expressed genes and can be expanded for detailed analysis. Click on the expand button (⛶) to view the plot in full screen. The PDF versions of these plots are also available for download.</p>

            <% dge_figures.forEach(function(fig) { %>
            <div class="card" style="margin-top: 25px; border: 1px solid #e2e8f0; border-radius: 6px; padding: 20px;">
                <h4 style="color: var(--primary-color); margin-bottom: 16px; font-size: 14px;">
                    Comparison: <%= fig.comparison %>
                </h4>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <!-- MA Plot -->
                    <div class="card" style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                        <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-weight: 600; font-size: 12px;">MA Plot</span>
                            <% if (fig.ma_volcano_pdf_src) { %>
                            <a href="<%= fig.ma_volcano_pdf_src %>" target="_blank" class="pdf-link" style="padding: 4px 8px; font-size: 10px; background: #fff; border: 1px solid #ddd; text-decoration: none;">⬇ PDF</a>
                            <% } %>
                        </div>
                        <div style="height: 350px; padding: 15px;">
                            <% if (fig.ma_plot_data) { %>
                            <canvas id="ma-<%= fig.comparison %>" class="ma-plot-canvas"></canvas>
                            <script type="application/json" id="plotdata-<%= fig.comparison %>"><%= fig.plot_data_json %></script>
                            <% } else if (fig.ma_volcano_pdf_src) { %>
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                <a href="<%= fig.ma_volcano_pdf_src %>" target="_blank" class="pdf-link" style="padding: 12px 24px; background: var(--primary-color); color: white; text-decoration: none; border-radius: 4px; font-size: 13px;">
                                    View MA Plot (PDF)
                                </a>
                            </div>
                            <% } else { %>
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                <span style="color: #666;">MA Plot data not available</span>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Volcano Plot -->
                    <div class="card" style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                        <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-weight: 600; font-size: 12px;">Volcano Plot</span>
                            <% if (fig.ma_volcano_pdf_src) { %>
                            <a href="<%= fig.ma_volcano_pdf_src %>" target="_blank" class="pdf-link" style="padding: 4px 8px; font-size: 10px; background: #fff; border: 1px solid #ddd; text-decoration: none;">⬇ PDF</a>
                            <% } %>
                        </div>
                        <div style="height: 350px; padding: 15px;">
                            <% if (fig.volcano_plot_data) { %>
                            <canvas id="volcano-<%= fig.comparison %>" class="volcano-plot-canvas"></canvas>
                            <% } else if (fig.ma_volcano_pdf_src) { %>
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                <a href="<%= fig.ma_volcano_pdf_src %>" target="_blank" class="pdf-link" style="padding: 12px 24px; background: var(--primary-color); color: white; text-decoration: none; border-radius: 4px; font-size: 13px;">
                                    View Volcano Plot (PDF)
                                </a>
                            </div>
                            <% } else { %>
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; background: #f8f9fa; border-radius: 4px;">
                                <span style="color: #666;">Volcano Plot data not available</span>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Heatmap -->
                <% if (fig.heatmap_png_src) { %>
                <div class="figure" style="margin-top: 20px;">
                    <div style="border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden;">
                        <div style="padding: 10px 15px; background: #f8f9fa; border-bottom: 1px solid #e2e8f0;">
                            <span style="font-weight: 600; font-size: 12px;">Expression Heatmap - <%= fig.comparison %></span>
                        </div>
                        <div style="padding: 15px;">
                            <img src="<%= fig.heatmap_png_src %>" alt="<%= fig.comparison %> heatmap" style="max-width: 100%; height: auto;" />
                        </div>
                    </div>
                    <p class="caption">Heatmap of significantly differentially expressed genes for <%= fig.comparison %></p>
                </div>
                <% } %>
            </div>
            <% }); %>

            <script>
                const __dgeCharts = { ma: {}, volcano: {} };

                function __getPlotData(comp) {
                    const el = document.getElementById('plotdata-' + comp);
                    if (!el) return null;
                    try {
                        return JSON.parse(el.textContent || '');
                    } catch (e) {
                        return null;
                    }
                }

                function __makeScatterChart(canvasId, titleText, datasets, xLabel, yLabel) {
                    const ctx = document.getElementById(canvasId);
                    if (!ctx) return null;

                    return new Chart(ctx, {
                        type: 'scatter',
                        data: {
                            datasets: datasets.map(ds => ({
                                label: ds.label,
                                data: ds.data,
                                backgroundColor: ds.backgroundColor || 'rgba(156,163,175,0.45)',
                                pointRadius: 3,
                                pointHoverRadius: 5
                            }))
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                title: {
                                    display: true,
                                    text: titleText,
                                    font: { size: 14, weight: '600' }
                                },
                                legend: {
                                    position: 'bottom',
                                    labels: { font: { size: 11 } }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return `(${context.parsed.x.toFixed(2)}, ${context.parsed.y.toFixed(2)})`;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    title: {
                                        display: true,
                                        text: xLabel,
                                        font: { size: 12 }
                                    }
                                },
                                y: {
                                    title: {
                                        display: true,
                                        text: yLabel,
                                        font: { size: 12 }
                                    }
                                }
                            }
                        }
                    });
                }

                // Initialize DGE charts
                <% if (typeof dge_figures !== 'undefined' && dge_figures) { %>
                <% dge_figures.forEach(function(fig) { %>
                (function() {
                    const data = __getPlotData('<%= fig.comparison %>');
                    if (!data) return;

                    // MA plot
                    const maCanvasId = 'ma-<%= fig.comparison %>';
                    if (data.ma && !__dgeCharts.ma['<%= fig.comparison %>'] && document.getElementById(maCanvasId)) {
                        const ds = [];
                        if (data.ma.ns && data.ma.ns.length) ds.push({ label: 'Not Sig', data: data.ma.ns, backgroundColor: 'rgba(156,163,175,0.45)' });
                        if (data.ma.down && data.ma.down.length) ds.push({ label: 'Down', data: data.ma.down, backgroundColor: 'rgba(59,130,246,0.65)' });
                        if (data.ma.up && data.ma.up.length) ds.push({ label: 'Up', data: data.ma.up, backgroundColor: 'rgba(239,68,68,0.65)' });
                        __dgeCharts.ma['<%= fig.comparison %>'] = __makeScatterChart(maCanvasId, 'MA Plot', ds, 'logCPM', 'log2FC');
                    }

                    // Volcano plot
                    const volCanvasId = 'volcano-<%= fig.comparison %>';
                    if (data.volcano && !__dgeCharts.volcano['<%= fig.comparison %>'] && document.getElementById(volCanvasId)) {
                        const ds = [];
                        if (data.volcano.ns && data.volcano.ns.length) ds.push({ label: 'Not Sig', data: data.volcano.ns, backgroundColor: 'rgba(156,163,175,0.45)' });
                        if (data.volcano.down && data.volcano.down.length) ds.push({ label: 'Down', data: data.volcano.down, backgroundColor: 'rgba(59,130,246,0.65)' });
                        if (data.volcano.up && data.volcano.up.length) ds.push({ label: 'Up', data: data.volcano.up, backgroundColor: 'rgba(239,68,68,0.65)' });
                        __dgeCharts.volcano['<%= fig.comparison %>'] = __makeScatterChart(volCanvasId, 'Volcano Plot', ds, 'log2FC', '-log10(p)');
                    }
                })();
                <% }); %>
                <% } %>
            </script>
            <% } %>
        </div>

        <!-- Section 11 -->
        <div id="section-11" class="section">
            <h2>11 Functional Annotation</h2>
            <p><%= static_snippets.go?.intro || 'The Gene Ontology project provides controlled vocabularies of defined terms representing gene product properties.' %></p>

            <div class="table-wrapper">
                <div class="table-title">Table 11.1: GO Domain Distribution</div>
                <table>
                    <thead>
                        <tr>
                            <th>Ontology</th>
                            <th>Term</th>
                            <th>Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% go_distribution.forEach(function(g) { %>
                        <tr>
                            <td><%= g.ontology %></td>
                            <td><%= g.term %></td>
                            <td><%= g.count %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <p><%= static_snippets.go?.deliverables_note || '' %></p>

            <h3>11.1 Pathway Analysis</h3>
            <p><%= static_snippets.pathway?.intro || 'Ortholog assignment and mapping of Significant differentially expressed transcripts to the biological pathways were performed using KEGG automatic annotation server (KAAS).' %></p>

            <% if (func_assets && func_assets.kegg_results_preview && func_assets.kegg_results_preview.length > 0) { %>
            <h3>KEGG Enrichment (preview)</h3>
            <% if (func_assets.kegg_results_xlsx) { %>
            <div class="figure">
                <a class="pdf-link" href="<%= func_assets.kegg_results_xlsx %>" target="_blank" rel="noopener noreferrer">Open KEGG enrichment results (XLSX)</a>
            </div>
            <% } %>
            <div class="table-wrapper">
                <div class="table-title">Top enriched KEGG pathways (first 10 rows)</div>
                <table>
                    <thead>
                        <tr>
                            <% if (func_assets.kegg_results_preview[0]) { %>
                                <% func_assets.kegg_results_preview[0].forEach(function(col) { %>
                                <th><%= col %></th>
                                <% }); %>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% func_assets.kegg_results_preview.slice(1).forEach(function(row) { %>
                        <tr>
                            <% row.forEach(function(cell) { %>
                            <td><%= cell %></td>
                            <% }); %>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } %>

            <% if (func_assets && func_assets.kegg_pathway_image_src) { %>
            <div class="figure">
                <img src="<%= func_assets.kegg_pathway_image_src %>" alt="KEGG pathway" />
                <p class="caption">Representative KEGG pathway image</p>
            </div>
            <% } %>

            <% if (pathway_ex_figure_src && (!func_assets || !func_assets.kegg_pathway_image_src)) { %>
            <div class="figure">
                <img src="<%= pathway_ex_figure_src %>" alt="KEGG pathway example" />
                <p class="caption">Representative pathway example</p>
            </div>
            <% } %>

            <h3>11.2 Enrichment Analysis</h3>
            <p><%= static_snippets.enrichment?.intro || 'Over-representation (enrichment) analysis is a statistical approach used to identify biological functions, pathways, or processes that are significantly over-represented.' %></p>

            <% if (func_assets && func_assets.enrichment_image_src) { %>
            <div class="figure">
                <img src="<%= func_assets.enrichment_image_src %>" alt="Enrichment plot" />
                <p class="caption">Representative enrichment plot</p>
            </div>
            <% } %>
        </div>

        <!-- Section 12 Deliverables -->
        <div id="section-12" class="section">
            <h2>12 Deliverables</h2>
            <p>The following deliverables were generated as part of this analysis:</p>
            <div class="table-wrapper">
                <div class="table-title">Deliverables Tree</div>
                <pre style="background: #f5f5f5; padding: 15px; border-radius: 5px; overflow-x: auto;"><%= deliverables_tree %></pre>
            </div>
        </div>

    </div>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // QC Chart
        const qcCtx = document.getElementById('qcChart');
        if (qcCtx) {
            new Chart(qcCtx, {
                type: 'bar',
                data: {
                    labels: <%= JSON.stringify(samples) %>,
                    datasets: [{
                        label: 'Library Size (bp)',
                        data: <%= JSON.stringify(library_sizes) %>,
                        backgroundColor: 'rgba(244, 121, 32, 0.7)',
                        borderColor: 'rgba(244, 121, 32, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Size (bp)'
                            }
                        }
                    }
                }
            });
        }

        // DGE Chart
        const dgeCtx = document.getElementById('dgeChart');
        if (dgeCtx && <%= dge_chart_labels %>.length > 0) {
            new Chart(dgeCtx, {
                type: 'bar',
                data: {
                    labels: <%= JSON.stringify(dge_chart_labels) %>,
                    datasets: [
                        {
                            label: 'Upregulated',
                            data: <%= JSON.stringify(dge_chart_up) %>,
                            backgroundColor: 'rgba(220, 38, 38, 0.7)',
                            borderColor: 'rgba(220, 38, 38, 1)',
                            borderWidth: 1
                        },
                        {
                            label: 'Downregulated',
                            data: <%= JSON.stringify(dge_chart_down) %>,
                            backgroundColor: 'rgba(49, 130, 206, 0.7)',
                            borderColor: 'rgba(49, 130, 206, 1)',
                            borderWidth: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Number of Genes'
                            }
                        }
                    }
                }
            });
        }
    </script>

</body>

</html>
